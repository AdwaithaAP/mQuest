    "relaxed":  ["relaxed","calm","romantic","nature"],
}
ACTIVITY_TAG_MAP = {
    "adventure":   ["adventure","thrilling","sports"],
    "food":        ["food","culture"],
    "nature":      ["nature","wildlife","forests"],
    "relaxation":  ["relaxed","calm","wellness"],
    "culture":     ["culture","history","spiritual"],
    "traveling":   ["adventure","excited","photography"],
}
ENVIRONMENT_TAG_MAP = {
    "mountains":   ["mountains"],
    "beaches":     ["beaches"],
    "cities":      ["cities"],
    "forests":     ["forests"],
    "countryside": ["countryside"],
}
EXPERIENCE_TAG_MAP = {
    "thrilling":  ["thrilling","adventure","excited","sports"],
    "calm":       ["calm","relaxed","nature"],
    "romantic":   ["romantic","couples"],
    "spiritual":  ["spiritual","solo"],
    "social":     ["friends","happy"],
    "cultural":   ["culture","history","photography"],
}

def _expand_inputs(answers):
    """Return a dict of tag sets, one per quiz dimension."""
    def resolve(value, mapping):
        if value in mapping:
            return set(mapping[value])
        for key in mapping:
            if key in value or value in key:
                return set(mapping[key])
        return set()

    return {
        'feeling':     resolve(answers.get('feeling','').lower(), FEELING_TAG_MAP),
        'activity':    resolve(answers.get('activity','').lower(), ACTIVITY_TAG_MAP),
        'environment': resolve(answers.get('environment','').lower(), ENVIRONMENT_TAG_MAP),
        'experience':  resolve(answers.get('experience','').lower(), EXPERIENCE_TAG_MAP),
    }

def _score_item(item_tags, dtags):
    """Score a place or activity against the 4-dimension tag sets."""
    tags = set(item_tags)
    score  = sum(3 for t in dtags['environment'] if t in tags)
    score += sum(2 for t in dtags['experience']  if t in tags)
    score += sum(2 for t in dtags['activity']    if t in tags)
    score += sum(1 for t in dtags['feeling']     if t in tags)
    return score

def _match_reason(place, dtags, raw):
    """Compose a human-readable reason why this place was recommended."""
    env  = raw.get('environment','destination')
    exp  = raw.get('experience','amazing')
    act  = raw.get('activity','exploring')
    feel = raw.get('feeling','great')
    opts = [
        f"A {exp} escape into {env} — perfectly matched to your {feel} mood and love of {act}.",
        f"Ideal for the {feel}-hearted traveller who craves a {exp} {env} {act} adventure.",
        f"Your {feel} spirit meets a {exp} {env} experience — built for {act} at its finest.",
        f"When {act} in {env} country with a {exp} twist is exactly what the mood calls for.",
    ]
    return opts[place.get('id', 0) % len(opts)]

