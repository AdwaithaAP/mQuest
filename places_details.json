def _build_restaurants(dtags):
    scored = []
    for r in ALL_RESTAURANTS:
        r_tags = set(r.get('tags', []))
        score  = sum(3 for t in dtags['environment'] if t in r_tags)
        score += sum(2 for t in dtags['experience']  if t in r_tags)
        score += sum(2 for t in dtags['activity']    if t in r_tags)
        score += sum(1 for t in dtags['feeling']     if t in r_tags)
        if r.get('env') == 'any':
            score = max(score, 1)   # always eligible as fallback
        scored.append((score, r))
    scored.sort(key=lambda x: (-x[0], random.random()))
    results = []
    for score, r in scored[:8]:
        entry = {k: v for k, v in r.items() if k not in ('tags','env')}
        entry['match_score'] = score
        results.append(entry)
    return results

# ── Auth Engine ───────────────────────────────────────────────────────────────

class AuthEngine:
    @staticmethod
    def signup(full_name, email, password):
        if not all([full_name, email, password]):
            return {'success':False,'message':'All fields are required'}, 400
        path = os.path.join(CREDENTIALS_DIR, f'{email}.json')
        if os.path.exists(path):
            return {'success':False,'message':'Email already registered'}, 409
        with open(path,'w') as f:
            json.dump({'fullName':full_name,'email':email,'password':password,
                       'createdAt':datetime.now().isoformat(),'lastLogin':None}, f, indent=2)
        return {'success':True,'message':'Account created','user':{'fullName':full_name,'email':email}}, 201

    @staticmethod
    def login(email, password):
        path = os.path.join(CREDENTIALS_DIR, f'{email}.json')
        if not os.path.exists(path):
            return {'success':False,'message':'Invalid email or password'}, 401
        with open(path,'r') as f:
            user = json.load(f)
        if user['password'] != password:
            return {'success':False,'message':'Invalid email or password'}, 401
        user['lastLogin'] = datetime.now().isoformat()
        with open(path,'w') as f:
            json.dump(user, f, indent=2)
        return {'success':True,'message':'Login successful','user':{'fullName':user['fullName'],'email':user['email']}}, 200

# ── Mood Engine v3 ────────────────────────────────────────────────────────────

class MoodEngine:

    @staticmethod
    def analyze(answers):
        feeling     = answers.get('feeling','').lower()
        activity    = answers.get('activity','').lower()
        experience  = answers.get('experience','').lower()
        environment = answers.get('environment','').lower()

        s = {m:0 for m in ['happy','sad','stressed','excited','bored','relaxed']}
        if feeling in s: s[feeling] += 3
        if 'adventure' in activity:   s['excited']+=2; s['happy']+=1
        elif 'food' in activity:       s['happy']+=2
        elif 'relaxation' in activity: s['relaxed']+=2
        elif 'traveling' in activity:  s['excited']+=2
        elif 'nature' in activity:     s['relaxed']+=1; s['happy']+=1
        if 'thrilling' in experience:  s['excited']+=2
        elif 'calm' in experience:     s['relaxed']+=2
        elif 'romantic' in experience: s['relaxed']+=1; s['happy']+=1
        elif 'spiritual' in experience:s['relaxed']+=1

        dominant = max(s, key=s.get)
        return {
            'dominant_mood': dominant,
            'mood_scores':   s,
            'inputs': {
                'feeling':     feeling,
                'activity':    activity,
                'environment': environment,
                'experience':  experience,
            }
        }

    @staticmethod
    def recommend(mood_profile):
        raw    = mood_profile.get('inputs', {})
        dtags  = _expand_inputs(raw)

        # Score and rank places
        scored_places = []
        for place in PLACES_DATA:
            score = _score_item(place.get('tags', []), dtags)
            scored_places.append((score, place))
        scored_places.sort(key=lambda x: (-x[0], random.random()))

        # Pool top 14, shuffle within ties, take 8
        pool_p = scored_places[:14]
        random.shuffle(pool_p)
        top_places = sorted(pool_p, key=lambda x: -x[0])[:8]

        result_places = []
        for score, place in top_places:
            p = dict(place)
            p['match_score']  = score
            p['match_reason'] = _match_reason(p, dtags, raw)
            for key in [p['name'], p['name'].split('(')[0].strip()]:
                if key in PLACE_COORDS:
                    p['coordinates'] = PLACE_COORDS[key]
                    break
            result_places.append(p)

        # Score and rank activities
        scored_acts = []
        for act in ACTIVITIES_DATA:
            score = _score_item(act.get('tags', []), dtags)
            scored_acts.append((score, act))
        scored_acts.sort(key=lambda x: (-x[0], random.random()))

        pool_a = scored_acts[:12]
        random.shuffle(pool_a)
        top_acts = sorted(pool_a, key=lambda x: -x[0])[:8]

        result_acts = []
        for score, act in top_acts:
            a = dict(act)
            a['match_score'] = score
            result_acts.append(a)

        return {
            'places':      result_places,
            'activities':  result_acts,
            'restaurants': _build_restaurants(dtags),
        }

# ── Place Detail ──────────────────────────────────────────────────────────────

class PlacesDetail:
    @staticmethod
    def get(name):
        lower = name.lower()
        for p in PLACES_DETAILS.get('places', []):
            if lower in p['name'].lower():
                if 'coordinates' not in p and p['name'] in PLACE_COORDS:
                    p['coordinates'] = PLACE_COORDS[p['name']]
                return p
        for p in PLACES_DATA:
            if lower in p['name'].lower():
                coords = PLACE_COORDS.get(p['name'], {"lat":0,"lng":0})
                return {
                    "id":p.get("id"),"name":p["name"],"category":p.get("category",""),
                    "state":p.get("state","India"),"address":f"{p['name']}, {p.get('state','India')}",
                    "coordinates":coords,"rating":p.get("rating"),"review_count":0,
                    "price_level":"Varies","phone":"—","website":"",
                    "opening_hours":{"open_now":True,"weekday_text":[]},
                    "photos":[],"reviews":[],"description":p.get("description",""),
                    "tags":p.get("tags",[]),"best_time":p.get("best_for",""),
                }
        return None

# ── HTTP Handler ──────────────────────────────────────────────────────────────

CORS = {
    'Access-Control-Allow-Origin':  '*',
    'Access-Control-Allow-Methods': 'GET, POST, OPTIONS',
    'Access-Control-Allow-Headers': 'Content-Type',
}

class Handler(BaseHTTPRequestHandler):
    def _cors(self):
        for k,v in CORS.items(): self.send_header(k,v)
    def _json(self, code, data):
        body = json.dumps(data, ensure_ascii=False).encode('utf-8')
        self.send_response(code)
        self.send_header('Content-Type','application/json; charset=utf-8')
        self._cors(); self.end_headers(); self.wfile.write(body)
    def _body(self):
        length = int(self.headers.get('Content-Length',0))
        raw = self.rfile.read(length).decode('utf-8')
        try: return json.loads(raw)
        except: return {}

    def do_GET(self):
        if self.path=='/health':
            self._json(200,{"status":"ok","version":"3.0","places":len(PLACES_DATA),"activities":len(ACTIVITIES_DATA)})
        elif self.path=='/places':
            self._json(200,{"count":len(PLACES_DATA),"places":PLACES_DATA})
        elif self.path=='/activities':
            self._json(200,{"count":len(ACTIVITIES_DATA),"activities":ACTIVITIES_DATA})
        elif self.path=='/api/coords':
            self._json(200,{"coords":PLACE_COORDS})
        else:
            self._json(404,{"error":"Not found"})

    def do_POST(self):
        data = self._body()
        if self.path=='/api/signup':
            r,c = AuthEngine.signup(data.get('fullName'),data.get('email'),data.get('password'))
            self._json(c,r)
        elif self.path=='/api/login':
            r,c = AuthEngine.login(data.get('email'),data.get('password'))
            self._json(c,r)
        elif self.path=='/recommend':
            mood = MoodEngine.analyze(data)
            recs = MoodEngine.recommend(mood)
            raw  = mood['inputs']
            self._json(200,{
                "success":True,
                "dominant_mood":mood['dominant_mood'],
                "mood_scores":mood['mood_scores'],
                "inputs":raw,
                "places":recs['places'],
                "activities":recs['activities'],
                "restaurants":recs['restaurants'],
                "message":(
                    f"Curated for a {raw.get('feeling','great')} mood — "
                    f"{raw.get('experience','amazing')} {raw.get('environment','destination')} "
                    f"perfect for {raw.get('activity','exploring')}!"
                ),
            })
        elif self.path=='/analyze-mood':
            mood = MoodEngine.analyze(data)
            self._json(200,{"success":True,**mood})
        elif self.path=='/api/place-detail':
            place = PlacesDetail.get(data.get('place_name',''))
            if place: self._json(200,{"success":True,"place":place})
            else: self._json(404,{"success":False,"message":"Not found"})
        elif self.path=='/api/overpass':
            query = data.get('query','')
            if not query: self._json(400,{"success":False,"message":"Missing query"}); return
            try:
                encoded = urllib.parse.urlencode({'data':query}).encode()
                req = urllib.request.Request(
                    'https://overpass-api.de/api/interpreter', data=encoded,
                    headers={'Content-Type':'application/x-www-form-urlencoded','User-Agent':'QUESTO/3.0'})
                with urllib.request.urlopen(req,timeout=20) as resp:
                    result = json.loads(resp.read().decode())
                self._json(200,{"success":True,"data":result})
            except Exception as e:
                self._json(502,{"success":False,"message":str(e)})
        else:
            self._json(404,{"error":"Endpoint not found"})

    def do_OPTIONS(self):
        self.send_response(200); self._cors(); self.end_headers()

    def log_message(self, fmt, *args):
        print(f"  [{self.client_address[0]}] {fmt%args}")

# ── Entry point ───────────────────────────────────────────────────────────────

def run(port=8000):
    server = HTTPServer(('',port), Handler)
    print(f"""
+------------------------------------------+
|    QUESTO Backend  v3 Enhanced           |
+------------------------------------------+
|  http://localhost:{port}                   |
|  {len(PLACES_DATA)} places  |  {len(ACTIVITIES_DATA)} activities loaded       |
|                                          |
|  POST /recommend        Tag-scored recs  |
|  POST /analyze-mood     Mood profile     |
|  POST /api/place-detail Place detail     |
|  POST /api/overpass     OSM proxy        |
|  GET  /places  /activities  /api/coords  |
+------------------------------------------+
  Press Ctrl+C to stop
""")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\n  Stopped."); server.server_close()

if __name__=='__main__':
    port = int(sys.argv[1]) if len(sys.argv)>1 else 8000
    run(port)
